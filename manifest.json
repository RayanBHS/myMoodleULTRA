{
  "manifest_version": 3,
  "name": "myMoodle ULTRA",
  "version": "1.0.0",
  "description": "Une interface moderne, épurée et ultra-rapide pour le Moodle de l'EFREI.",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://tmpfiles.org/"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "img/logoMyMoodleUltra.png",
      "32": "img/logoMyMoodleUltra.png",
      "48": "img/logoMyMoodleUltra.png",
      "128": "img/logoMyMoodleUltra.png"
    }
  },
  "icons": {
    "16": "img/logoMyMoodleUltra.png",
    "32": "img/logoMyMoodleUltra.png",
    "48": "img/logoMyMoodleUltra.png",
    "128": "img/logoMyMoodleUltra.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "img/*"
      ],
      "matches": [
        "*://moodle.myefrei.fr/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://*.perplexity.ai/*"
      ],
      "js": [
        "js/ai_injector.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://moodle.myefrei.fr/*"
      ],
      "js": [
        "js/interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://moodle.myefrei.fr/*"
      ],
      "js": [
        "js/vendor/jszip.min.js",
        "js/vendor/docx-preview.js",
        "js/vendor/pptx-canvas-renderer.umd.js",
        "js/theme.js",
        "js/navbar.js",
        "js/hero.js",
        "js/courses.js",
        "js/calendar.js",
        "js/timeline.js",
        "js/viewer.js",
        "js/messages.js",
        "js/main.js"
      ],
      "css": [
        "css/variables.css",
        "css/general.css",
        "css/navbar.css",
        "css/hero.css",
        "css/courses.css",
        "css/calendar.css",
        "css/timeline.css",
        "css/viewer.css",
        "css/messages.css"
      ],
      "run_at": "document_start"
    }
  ]
}
